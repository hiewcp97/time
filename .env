# ==========================================
# Retention Agent Platform Configuration
# ==========================================

# Database & Cache connection details
# (Used when running Go binary directly on host, Docker compose overrides database host config)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/retention?sslmode=disable
REDIS_URL=localhost:6379
PORT=8080

# Google Gemini LLM API details
# Provide your Google Gemini API Key below to enable actual LLM generations.
# Leave blank to fall back to the built-in mock sales pitch generator.
GEMINI_API_KEY=

# Target model name (e.g. gemini-1.5-flash, gemini-1.5-pro, etc.)
LLM_MODEL=gemini-1.5-flash
